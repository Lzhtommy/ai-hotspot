# ============================================================
# AI Hotspot — Environment Variables
# Source of truth for variable names across all three vaults:
# 1. Vercel project env (Next.js runtime)
# 2. Trigger.dev Cloud env (worker runtime)
# 3. Hugging Face Space (RSSHub config — set in HF Space secrets UI)
#
# DO NOT commit actual values. This file documents names only.
# ============================================================

# --- Database (Vercel + Trigger.dev) ---
DATABASE_URL=
# CI note: DATABASE_URL is set per-PR by create-branch-action output

# --- Redis (Vercel) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Trigger.dev (Vercel runtime — for triggering tasks) ---
TRIGGER_SECRET_KEY=

# --- Trigger.dev (CLI / GitHub Actions CI — for deployment) ---
TRIGGER_ACCESS_TOKEN=

# --- RSSHub (Vercel + Trigger.dev) ---
RSSHUB_BASE_URL=
RSSHUB_ACCESS_KEY=

# --- LLM APIs (Vercel + Trigger.dev) ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- Authentication (Vercel) ---
AUTH_SECRET=
# Required. Byte-identical across Production + Preview + Development scopes.
# Different values break preview OAuth via redirect proxy (RESEARCH §Pitfall 3).
# Generate with: openssl rand -base64 32

AUTH_URL=
# Production canonical URL, e.g. https://aihotspot.com
# Unset on preview; Auth.js v5 reads VERCEL_URL as fallback.

AUTH_REDIRECT_PROXY_URL=
# Preview-only. Set in Vercel preview env scope ONLY; unset on production.
# Points preview deployments at production's /api/auth for OAuth callback.
# Example: https://aihotspot.com/api/auth

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

RESEND_API_KEY=

RESEND_FROM=
# Email sender in "Display Name <email@domain>" format.
# Example: "AI Hotspot <noreply@aihotspot.com>"
# For pre-DNS-verification testing, use onboarding@resend.dev.

# --- Observability (Vercel + Trigger.dev) — placeholders; implemented in Phase 6 ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# --- Sentry (Phase 6 OPS-01) ---
# Server + Trigger.dev DSN. Set in Vercel (Production/Preview/Development) + Trigger.dev env.
SENTRY_DSN=
# Browser DSN — same value as SENTRY_DSN, exposed to the client bundle via NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_SENTRY_DSN=
# Build-time sourcemap upload token (scope: "project:releases" + "project:read").
# Set in Vercel Build env + GitHub Actions secrets; NEVER commit. Absent = sourcemap
# upload silently skipped (builds still succeed).
SENTRY_AUTH_TOKEN=
# Sentry organization slug (withSentryConfig build-time org/project coordinates).
SENTRY_ORG=
# Sentry project slug.
SENTRY_PROJECT=

# --- Neon CI (GitHub Actions secrets/vars — not in Vercel) ---
# NEON_API_KEY=
# NEON_PROJECT_ID=

# --- Feed UI — Phase 4 ---
# Absolute base URL for og:image / canonical / revalidate POST target.
# Fallback chain at runtime: NEXT_PUBLIC_SITE_URL → https://${VERCEL_URL} → https://localhost:3000
NEXT_PUBLIC_SITE_URL=
# Shared secret for POST /api/revalidate (set in Vercel env AND Trigger.dev env — same value both sides).
REVALIDATE_SECRET=

# --- HF Space variables (set in HF Space secrets UI, not here) ---
# ALLOW_USER_HOTLINK=false
# DISALLOW_ROBOT=true
# REQUEST_RETRY=2
# CACHE_EXPIRE=900
# CACHE_CONTENT_EXPIRE=3600
# ACCESS_KEY=<same value as RSSHUB_ACCESS_KEY>
