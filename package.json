{
  "name": "ai-hotspot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium",
    "verify:feed": "tsx --env-file=.env.local scripts/verify-feed.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local drizzle/seed-sources.ts",
    "db:apply:0005": "tsx --env-file=.env.local scripts/apply-0005-admin-ops.ts",
    "verify:ingest": "tsx --env-file=.env.local scripts/verify-ingest.ts",
    "verify:llm": "tsx --env-file=.env.local scripts/verify-llm.ts",
    "check:hnsw": "tsx --env-file=.env.local scripts/check-hnsw.ts",
    "verify:hnsw": "tsx --env-file=.env.local scripts/check-hnsw.ts",
    "trigger:dev": "pnpm dlx trigger.dev@latest dev",
    "trigger:deploy": "pnpm dlx trigger.dev@latest deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@arizeai/openinference-instrumentation-anthropic": "^0.1.9",
    "@auth/drizzle-adapter": "1.11.2",
    "@langfuse/otel": "^5.1.0",
    "@mozilla/readability": "^0.6.0",
    "@neondatabase/serverless": "^1.0.2",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@trigger.dev/sdk": "^4.4.4",
    "@upstash/redis": "^1.37.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "jsdom": "^29.0.2",
    "next": "^15",
    "next-auth": "5.0.0-beta.31",
    "nuqs": "^2.8.9",
    "react": "^18",
    "react-dom": "^18",
    "rss-parser": "^3.13.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trigger.dev/build": "^4.4.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^2.1.9",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "trigger.dev": "^4.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  }
}
